
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["gcp_project_id", "gcp_region", "gcp_zone", "project_prefix", "admin_src_addr", "compute", "bigip_base", "xc"],
  "properties": {
    "gcp_project_id": { "type": "string", "minLength": 1 },
    "gcp_region": { "type": "string", "minLength": 1 },
    "gcp_zone": { "type": "string", "minLength": 1 },
    "project_prefix": { "type": "string", "minLength": 1 },
    "resource_owner": { "type": "string" },
    "admin_src_addr": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "compute": {
      "type": "object",
      "required": ["gcp_runtime_service_account_email"],
      "properties": {
        "gcp_runtime_service_account_email": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": true
    },
    "bigip_base": {
      "type": "object",
      "required": ["image_name", "ssh_key"],
      "properties": {
        "image_name": { "type": "string", "minLength": 1 },
        "ssh_key": { "type": "string", "minLength": 10 }
      },
      "additionalProperties": true
    },
    "xc": {
      "type": "object",
      "required": ["xc_tenant", "api_url", "xc_namespace", "app_domain"],
      "properties": {
        "xc_tenant": { "type": "string", "minLength": 1 },
        "api_url": { "type": "string", "minLength": 1 },
        "xc_namespace": { "type": "string", "minLength": 1 },
        "app_domain": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
