{
    "class": "ADC",
    "schemaVersion": "3.26.0",
    "id": "LTM_HTTP_VS",
    "Tenant_1": {
        "class": "Tenant",
        "A1": {
            "class": "Application",
            "template": "http",
            "serviceMain": {
                "class": "Service_HTTP",
                "virtualAddresses": [
                    "0.0.0.0"
                ],
                "pool": "web_pool"
            },
            "web_pool": {
                "class": "Pool",
                "monitors": [
                    "http"
                ],
                "members": [{
                    "servicePort": 80,
                    "serverAddresses": [
                       "${app_server_ip}"
                    ]
                }]
            }
        }
    }
}